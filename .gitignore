# Terraform working directories
**/.terraform/*

# Terraform state
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plans
*.tfplan
tfplan

# Terraform crash logs
crash.log
crash.*.log

# Terraform variable files may contain sensitive values
*.tfvars
*.tfvars.json

# Keep examples
!*.tfvars.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# Environment variables
.env
.env.*

# IDE and operating system
.vscode/
.idea/
.DS_Store
Thumbs.db
